# Retell
# Put real keys only in .env. Do not commit real secrets.
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_CONVERSATION_FLOW_ID=
RETELL_PHONE_NUMBER=
RETELL_WEBHOOK_SECRET_OR_API_KEY=
RETELL_TRANSFER_PHONE_NUMBER=
RETELL_AGENT_NAME=Elijah's Pest Control Demo Receptionist
RETELL_VOICE_ID=11labs-Cimo
RETELL_KNOWLEDGE_BASE_ID=knowledge_base_5c6a5b20b1a9ed4f
RETELL_SINGLE_PROMPT_CANDIDATE_AGENT_ID=
RETELL_SINGLE_PROMPT_CANDIDATE_LLM_ID=

# Retell SMS controls
# Default is safe: backend simulates SMS unless a verified provider path is enabled.
RETELL_SMS_NODE_ENABLED=false
RETELL_OUTBOUND_SMS_ENABLED=false
RETELL_SMS_CHAT_AGENT_ID=

# Public/backend URLs
PUBLIC_BASE_URL=
RETELL_WEBHOOK_URL=
TOOLS_BASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_DB_URL=

# Demo booking
BOOKING_URL=
DEFAULT_BUSINESS_NAME=Elijah's Pest Control
DEFAULT_BUSINESS_PHONE=
DEFAULT_BUSINESS_TIMEZONE=America/New_York

# SMS
SMS_MODE=retell
SMS_FROM_NUMBER=
SMS_BOOKING_MESSAGE_TEMPLATE=Hi {{caller_name}}, here is the booking link for {{business_name}} pest control service: {{booking_url}}. Please choose a time and enter your service details there.

# Optional future calendar integration
CALENDAR_PROVIDER=none
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_USERNAME=
CALCOM_EVENT_SLUG=
BOOKING_PLACEHOLDER_EMAIL=demo@example.com

# Optional Google Sheets call-summary mirror
# Supabase remains primary storage. Sheets is a reporting mirror.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=1EO6ncmbNuFEOX6Bkt3ETCWb8pvkG_ZflWNexwT8MXKs
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_TAB_NAME=Call Logs

# Optional Apps Script fallback instead of service-account API writes.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Retell webhook local development
ALLOW_UNVERIFIED_WEBHOOKS=false

# Outbound collections demo
# Existing RETELL_AGENT_ID and RETELL_CONVERSATION_FLOW_ID above remain receptionist-only.
APP_BASE_URL=
OUTBOUND_ADMIN_TOKEN=
OUTBOUND_TEST_MODE=true
OUTBOUND_TEST_PHONE_ALLOWLIST=
OUTBOUND_MAX_BATCH_SIZE=3

OUTBOUND_RETELL_AGENT_ID=
OUTBOUND_RETELL_CONVERSATION_FLOW_ID=
OUTBOUND_RETELL_PHONE_NUMBER_ID=
OUTBOUND_RETELL_AGENT_NAME=Outbound B2B Invoice Collections Demo
OUTBOUND_RETELL_VOICE_ID=11labs-Cimo
OUTBOUND_RETELL_WEBHOOK_SECRET=
OUTBOUND_RETELL_SMS_ENABLED=false
OUTBOUND_RETELL_SMS_CHAT_AGENT_ID=
CONFIRM_CREATE_RETELL_OUTBOUND_AGENT=false
RETELL_FROM_NUMBER=+19842075346

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

HUMAN_TRANSFER_NUMBER=
BUSINESS_CALLBACK_NUMBER=
EMAIL_PROVIDER_API_KEY=

# Optional deployment
PORT=3000
NODE_ENV=development
VERCEL_ENV=
